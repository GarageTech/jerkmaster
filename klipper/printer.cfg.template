# JerkMaster - BTT SKR 1.4 Turbo
#
# Generated by tools/bootstrap.sh from this template.

[include hardware.cfg]
[include macros.cfg]

[mcu]
serial: {{MCU_SERIAL}}

[printer]
kinematics: none
max_velocity: 1
max_accel: 1

[virtual_sdcard]
path: ~/printer_data/gcodes

[display_status]

[pause_resume]

[respond]

[idle_timeout]
# Safety fallback. The drying state machine refreshes this timer at every stage.
timeout: 43200
gcode:
  STOP_DRYING REASON=idle_timeout
